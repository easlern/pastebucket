[Unit]
Description=Pastebucket - Minimalist Real-time Collaborative Editor
After=network.target

[Service]
# Replace 'youruser' with your actual server username
User=youruser
Group=youruser
WorkingDirectory=/home/youruser/pastebucket
ExecStart=/home/youruser/pastebucket/.venv/bin/python main.py
Restart=always
# Change 'pastebucket' to your app name and '3000' to a unique port
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
